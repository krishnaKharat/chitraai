<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Top green line indicator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@color/primary_green"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Connected Badge -->
    <TextView
        android:id="@+id/tv_connected_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● LIVE"
        android:textColor="@color/primary_green"
        android:textSize="12sp"
        android:fontFamily="@font/inter_semibold"
        android:letterSpacing="0.12"
        android:background="@drawable/badge_live"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Session Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSession"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_connected_badge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <!-- Connected indicator pulse -->
            <ImageView
                android:id="@+id/iv_connected_indicator"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_connected_ring"
                android:contentDescription="Connected"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/tv_session_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Krish is helping you"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:fontFamily="@font/poppins_semibold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Screen is being shared securely"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular"
                android:gravity="center"
                android:layout_marginTop="6dp" />

            <!-- Duration -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/duration_badge"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginTop="20dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_clock"
                    android:contentDescription="Duration" />

                <TextView
                    android:id="@+id/tv_session_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/accent_gold"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Actions Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@+id/cardSession"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/inter_semibold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btn_share_file"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="📂  Share a File with Krish"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:fontFamily="@font/inter_semibold"
                android:background="@drawable/btn_secondary"
                android:stateListAnimator="@null"
                android:layout_marginBottom="10dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- End Session Button -->
    <Button
        android:id="@+id/btn_end_session"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="End Session"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:fontFamily="@font/poppins_semibold"
        android:background="@drawable/btn_danger"
        android:stateListAnimator="@null"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
